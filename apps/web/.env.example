# Copy to .env and fill in (never commit .env).

ANYTHING_PROJECT_TOKEN=

# Google Sheets webhook — Web App URL ending in /exec
GOOGLE_SHEETS_APPS_SCRIPT_URL=

# Optional: must match Script property WEBHOOK_SECRET in Apps Script
# GOOGLE_APPS_SCRIPT_SECRET=

# Optional: separate *media-only* Git repo (large videos). Run: npm run sync:media
# MEDIA_REPO_URL=https://github.com/shuesca/project1-media.git
